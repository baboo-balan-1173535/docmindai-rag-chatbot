# DocMind AI — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# ── Anthropic (required) ──────────────────────────────────────
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Brave Search (optional) ───────────────────────────────────
# Get a free key from https://api.search.brave.com/
# If not set, web search toggle will be hidden in the UI.
BRAVE_API_KEY=your-brave-api-key-here

# ── PostgreSQL connection (required) ─────────────────────────
# Format: postgresql://username:password@host:port/database
# Replace 'postgres' and 'yourpassword' with your pgAdmin credentials.
# The database name 'kiwi_sorter' is shared with the kiwi sorter system.
PG_CONNECTION=postgresql://postgres:yourpassword@localhost:5432/kiwi_sorter

# ── Flask session secret (required for persistent sessions) ───
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
# If not set, sessions reset every time Flask restarts (fine for dev, bad for prod).
FLASK_SECRET_KEY=generate-a-random-string-here
